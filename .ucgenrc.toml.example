# ucgen configuration example
# Copy this file to .ucgenrc.toml and customize values.

[defaults]
provider = "ollama"
model = "mistral"
output_dir = "./use-cases"
template = "default"
id_prefix = "UC"
temperature = 0.3
max_tokens = 2000

[providers]
ollama_base_url = "http://localhost:11434"
custom_base_url = ""
custom_prompts_dir = ""

[hooks]
on_generate = ""
on_batch_complete = ""
